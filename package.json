{
  "name": "arcane-dominion",
  "version": "0.1.0",
  "description": "Arcane Dominion - a mobile-first PWA RTS (Red Alert 2 meets Wizard Duels).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "node relay/production.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "validate-data": "vitest run tests/architecture.test.ts -t \"content validation\"",
    "test": "vitest run --exclude tests/balance.test.ts",
    "test:slow": "vitest run tests/balance.test.ts",
    "test:full": "vitest run",
    "test:e2e": "playwright test",
    "relay": "node relay/server.mjs"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "pixi.js": "^8.6.6",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.51.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
