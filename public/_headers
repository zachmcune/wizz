# Cloudflare Pages cache rules. Prevents players getting stuck on a stale build:
# HTML + service worker revalidate; content-hashed assets are immutable/long-cached.
/index.html
  Cache-Control: no-cache
/sw.js
  Cache-Control: no-cache
/registerSW.js
  Cache-Control: no-cache
/manifest.webmanifest
  Cache-Control: no-cache
/workbox-*.js
  Cache-Control: no-cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable
