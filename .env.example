# Optional: override WebSocket URL for the lockstep relay.
# Not needed on Railway all-in-one (HTTPS pages auto-use wss://same-host).
# Local dev defaults to ws://<hostname>:8787 when unset.
# Only set for split hosting (e.g. game on Cloudflare Pages, relay elsewhere).
# VITE_RELAY_URL=wss://relay.example.com
